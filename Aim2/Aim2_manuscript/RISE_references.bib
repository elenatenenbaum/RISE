@article{imafuku2017,
  title = {Preference for {{Dynamic Human Images}} and {{Gaze-Following Abilities}} in {{Preterm Infants}} at 6 and 12 {{Months}} of {{Age}}: {{An Eye-Tracking Study}}},
  shorttitle = {Preference for {{Dynamic Human Images}} and {{Gaze-Following Abilities}} in {{Preterm Infants}} at 6 and 12 {{Months}} of {{Age}}},
